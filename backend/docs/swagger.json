            "delete": {
                "security": [
                    {
                        "CookieAuth": []
                    },
                    {
                        "BearerAuth": []
                    }
                ],
                "tags": [
                    "integrations"
                ],
                "summary": "Disconnect the integration",
                "parameters": [
                    {
                        "type": "string",
                        "default": "jira",
