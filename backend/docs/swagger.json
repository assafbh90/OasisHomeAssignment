{
    "swagger": "2.0",
    "info": {
        "description": "Multi-tenant API to connect a Jira Cloud workspace (OAuth 3LO)\nand file NHI finding tickets — from the UI and from a REST API\nguarded by a machine API key.",
        "title": "IdentityHub API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
