    "securityDefinitions": {
        "BearerAuth": {
            "description": "Machine API key as \"Bearer ih_pat_…\" (issue one via POST /v1/tokens).",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        },
        "CookieAuth": {
            "description": "Interactive session cookie (set by POST /v1/auth/login).",
            "type": "apiKey",
            "name": "ih_session",
            "in": "cookie"
        }
    }
