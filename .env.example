# ---------------------------------------------------------------------------
# IdentityHub environment. Copy to `.env` and fill in secrets.
# `.env` is git-ignored; never commit real secrets.
# Env vars override config-file/defaults. Nested config keys map to UPPER_SNAKE,
# e.g. postgres.host -> POSTGRES_HOST.
# ---------------------------------------------------------------------------

# dev | prod  (controls log format: text in dev, JSON in prod)
ENV=dev
LOG_LEVEL=info

# --- HTTP ---
HTTP_ADDR=:8080
PPROF_ENABLED=true
PPROF_ADDR=127.0.0.1:6060

# --- Postgres roles -------------------------------------------------------
# Two roles by design: a SUPERUSER for migrations/admin (bypasses RLS), and a
# least-privilege app role the backend connects as (so RLS actually applies).
PG_SUPERUSER=identityhub_admin
PG_SUPERUSER_PASSWORD=admin_pw_change_me
PG_DB=identityhub
# Password for the app role `identityhub_app` (created by the postgres init script).
APP_DB_PASSWORD=app_pw_change_me

# --- Backend DB connection (config reads POSTGRES_*) ----------------------
# USER is the least-privilege app role; PASSWORD MUST equal APP_DB_PASSWORD.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=identityhub_app
POSTGRES_PASSWORD=app_pw_change_me
POSTGRES_DB=identityhub
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=20

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=redis_pw_change_me
REDIS_DB=0

# --- Sessions ---
SESSION_TTL=24h
SESSION_ABSOLUTE_TTL=168h
SESSION_COOKIE_NAME=ih_session
# Set true behind TLS (production). false for local http dev.
SESSION_COOKIE_SECURE=false

# --- Crypto (Jira tokens at rest, AES-256-GCM) ---
# 32-byte key, base64-std encoded. Generate: `openssl rand -base64 32`
CRYPTO_TOKEN_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# --- API tokens (machine keys for the REST API) ---
API_TOKEN_PREFIX=ih_pat
API_TOKEN_CACHE_TTL=60s

# --- Rate limiting (login) ---
RATELIMIT_LOGIN_MAX=10
RATELIMIT_LOGIN_WINDOW=1m

# --- Jira Cloud 3LO -------------------------------------------------------
# Create an OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# The stack boots without these, but the Jira integration can't complete OAuth
# until they are set.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# The OAuth callback URL is derived from PUBLIC_HOST (see bottom) by docker-compose,
# so it can't drift from where the stack is reachable. Register that same URL in
# the Atlassian console:  http://${PUBLIC_HOST}/v1/integrations/jira/callback
# Uncomment to fully override the scheme/path too (e.g. https in production):
# JIRA_REDIRECT_URI=https://app.example.com/v1/integrations/jira/callback
JIRA_SCOPES=read:jira-work,write:jira-work,read:jira-user,offline_access
JIRA_AUTH_URL=https://auth.atlassian.com/authorize
JIRA_TOKEN_URL=https://auth.atlassian.com/oauth/token
JIRA_API_BASE_URL=https://api.atlassian.com
JIRA_USE_PKCE=true
JIRA_INACTIVITY_WINDOW=2160h
JIRA_ACCESS_TOKEN_SKEW=60s

# --- Demo seed (the `seed` subcommand / compose `seed` service) -----------
# The first organization + user created on `task up`. Login with these.
# Change them for your environment; the password is shown in the seed logs.
SEED_ORG_SLUG=acme
SEED_ORG_NAME=Acme Corp
SEED_USER_EMAIL=admin@acme.test
SEED_USER_PASSWORD=password123

# --- Frontend / public origin ------------------------------------------------
# FRONTEND_PORT is the published port. PUBLIC_HOST is the full browser-facing
# authority (host[:port]) the Jira callback URL is derived from; leave it unset
# and it defaults to localhost:${FRONTEND_PORT}, so local dev needs only the port.
# Set it to a bare domain in prod (e.g. app.example.com) to drop the :port.
# PUBLIC_HOST=app.example.com
FRONTEND_PORT=3000
